      "heightPx": 4096,
      "license": "MIT",
      "attribution": "elpwc/EldenRingOnlineMap (MIT)",
      "sourceUrl": "https://github.com/elpwc/EldenRingOnlineMap",
      "commercialUseOk": true
    },
