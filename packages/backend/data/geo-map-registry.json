    },
    {
      "match": { "slug": "genshin-impact" },
      "imageUrl": "https://raw.githubusercontent.com/Teyvat-Moe/Teyvat.moe/develop/public/textures/teyvat.png",
      "widthPx": 8192,
      "heightPx": 8192,
      "license": "GPL-3.0",
